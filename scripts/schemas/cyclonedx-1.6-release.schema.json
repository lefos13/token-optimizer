{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cyclonedx.org/schema/bom-1.6.release-subset.schema.json",
  "title": "CycloneDX 1.6 npm release validation subset",
  "description": "Pinned release subset derived from CycloneDX bom-1.6.schema.json (Apache-2.0, https://github.com/CycloneDX/specification/blob/1.6/schema/bom-1.6.schema.json).",
  "type": "object",
  "additionalProperties": true,
  "required": ["bomFormat", "specVersion", "serialNumber", "version", "metadata", "components"],
  "properties": {
    "bomFormat": { "const": "CycloneDX" },
    "specVersion": { "enum": ["1.5", "1.6"] },
    "serialNumber": { "type": "string", "minLength": 1 },
    "version": { "type": "integer", "minimum": 1 },
    "metadata": {
      "type": "object", "required": ["timestamp", "component"],
      "properties": { "timestamp": { "type": "string", "format": "date-time" }, "component": { "$ref": "#/$defs/component" } }
    },
    "components": { "type": "array", "items": { "$ref": "#/$defs/component" } }
  },
  "$defs": { "component": { "type": "object", "required": ["type", "bom-ref", "name", "version"], "properties": { "type": { "type": "string" }, "bom-ref": { "type": "string", "minLength": 1 }, "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 } } } }
}
