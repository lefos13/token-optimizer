{
  "name": "local-tester-mcp",
  "version": "1.0.0",
  "description": "An MCP server for running workspace tests and triaging failures using a local LLM.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:gateway": "tsc -p tsconfig.gateway.json",
    "start:gateway": "node gateway/dist/index.js",
    "test": "tsc -p tsconfig.test.json && node --test \"./.test-build/test/**/*.test.js\"",
    "build:plugin": "npm run build:plugin:antigravity && npm run build:plugin:claude && npm run build:plugin:codex",
    "build:plugin:antigravity": "node scripts/generate-plugin-antigravity.js",
    "build:plugin:claude": "node scripts/generate-plugin-claude.js",
    "build:plugin:codex": "node scripts/generate-plugin-codex.js",
    "openrouter:config": "node scripts/manage-openrouter-config.js",
    "start": "node dist/index.js",
    "dev": "tsc -w",
    "analytics:ui": "npm run build && node dist/analytics-ui.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  }
}
