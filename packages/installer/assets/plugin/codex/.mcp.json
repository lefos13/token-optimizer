{
  "mcpServers": {
    "token_optimizer": {
      "command": "node",
      "args": [
        "server/start.js"
      ],
      "cwd": ".",
      "env_vars": [
        "LLM_GATEWAY_TOKEN",
        "LLM_GATEWAY_URL",
        "OPENROUTER_BYOK_KEY",
        "OPENROUTER_BYOK_MODEL",
        "OPENROUTER_MODEL",
        "OPENROUTER_API_URL"
      ],
      "env": {
        "LLM_GATEWAY_URL": "https://llm-proxy.lnf.gr/v1",
        "LOCAL_LLM_API_URL": "http://localhost:8080/v1",
        "LOCAL_LLM_MODEL": "local-model"
      }
    }
  }
}
