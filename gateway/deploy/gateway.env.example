# Copy to /etc/local-tester-gateway.env, chmod 600, fill in real values. NEVER commit the real file.
PORT=8787
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# Comma-separated list of accepted proxy tokens (generate with: openssl rand -hex 32)
PROXY_TOKENS=REPLACE_WITH_LONG_RANDOM_TOKEN
DEFAULT_MODEL=openai/gpt-4o-mini
# Optional per-task overrides; blank = use DEFAULT_MODEL
MODEL_VERDICT=
MODEL_TRIAGE=
MODEL_REVIEW=
MODEL_DIGEST=
MODEL_SCOUT=
MODEL_QUERY=
RATE_LIMIT_PER_MIN=60
MAX_BODY_BYTES=262144
UPSTREAM_TIMEOUT_MS=60000
# Directory for persistent gateway state (issued tokens + global stats); relative paths resolve against the working directory.
# Under pm2 the default resolves to /opt/local-tester-gateway/.data; under systemd set STATE_DIR=/var/lib/local-tester-gateway (see the unit file).
STATE_DIR=.data
# Bearer token for the /admin dashboard and API (generate with: openssl rand -hex 32). Leave blank to disable all admin routes.
ADMIN_TOKEN=
# Default per-day call allowance for issued (email-approved) tokens
DEFAULT_DAILY_LIMIT=20
# Per-IP per-minute cap on public POST /v1/token-requests
TOKEN_REQUESTS_PER_MIN=3
# Optional Nodemailer delivery for approved tokens. GMAIL_USER also receives a
# best-effort alert after each newly accepted public token request.
# Use EMAIL_PROVIDER=gmail with the same Gmail app-password credentials as softaware-apis,
# or set EMAIL_PROVIDER=smtp.
EMAIL_PROVIDER=gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_REPLY_TO=
# Whether a caller-supplied X-OpenRouter-Key (bring-your-own-key, unlimited usage) is honored. Set to false to disable BYOK entirely.
ALLOW_BYOK=true
